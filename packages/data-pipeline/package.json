{
    "name": "@codex-scriptura/data-pipeline",
    "version": "0.3.2",
    "private": true,
    "type": "module",
    "scripts": {
        "fetch:texts": "tsx src/fetch-texts.ts",
        "import:osis": "tsx src/import-kjv-osis.ts",
        "import:web": "tsx src/import-web-usfx.ts",
        "import:all": "tsx src/import-kjv-osis.ts && tsx src/import-web-usfx.ts",
        "fetch:theographic": "tsx src/fetch-theographic.ts",
        "import:theographic": "tsx src/import-theographic.ts",
        "copy": "tsx src/copy-to-static.ts",
        "setup:texts": "pnpm run fetch:texts && pnpm run import:all",
        "setup:theographic": "pnpm run fetch:theographic && pnpm run import:theographic",
        "setup:enrichment": "pnpm run fetch:openbible && pnpm run enrich:places && pnpm run fetch:bibledata && pnpm run enrich:persons",
        "setup": "pnpm run setup:texts && pnpm run setup:theographic && pnpm run setup:enrichment && pnpm run copy",
        "fetch:openbible": "tsx src/fetch-openbible.ts",
        "enrich:places": "tsx src/enrich-places-openbible.ts",
        "fetch:bibledata": "tsx src/fetch-bibledata.ts",
        "enrich:persons": "tsx src/enrich-persons-bibledata.ts"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}