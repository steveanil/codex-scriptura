{
	"name": "codex-scriptura",
	"private": true,
	"version": "0.3.2",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"data:all": "cd packages/data-pipeline && pnpm run setup",
		"data:texts": "cd packages/data-pipeline && pnpm run setup:texts",
		"data:theographic": "cd packages/data-pipeline && pnpm run setup:theographic",
		"data:enrichment": "cd packages/data-pipeline && pnpm run setup:enrichment",
		"data:crossrefs": "cd packages/data-pipeline && pnpm run setup:crossrefs",
		"data:genealogy": "cd packages/data-pipeline && pnpm run import:genealogy",
		"data:lexicon": "cd packages/data-pipeline && pnpm run setup:lexicon",
		"data:copy": "cd packages/data-pipeline && pnpm run copy",
		"setup:data": "cd packages/data-pipeline && pnpm run setup"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/svelte": "^5.3.1",
		"@types/d3-force": "^3.0.10",
		"@types/leaflet": "^1.9.21",
		"fake-indexeddb": "^6.2.5",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@codex-scriptura/core": "workspace:*",
		"@codex-scriptura/db": "workspace:*",
		"d3-force": "^3.0.0",
		"leaflet": "^1.9.4",
		"minisearch": "^7.2.0"
	}
}
